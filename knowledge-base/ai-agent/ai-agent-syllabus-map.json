{
    "subject": "AI Agent Development",
    "subjectId": "ai-agent-development",
    "syllabusVersion": "2025",
    "appliesTo": "Intermediate Python developers building LLM-powered agents",
    "learningPath": {
        "totalDuration": "160 hours",
        "levels": [
            { "level": "Foundation",    "estimatedHours": 40, "topics": ["Agent Concepts", "LLM Fundamentals", "Prompt Engineering"] },
            { "level": "Intermediate",  "estimatedHours": 70, "topics": ["Tools and Function Calling", "Memory Systems", "RAG Pipelines", "LangChain", "LlamaIndex"] },
            { "level": "Advanced",      "estimatedHours": 50, "topics": ["LangGraph", "Multi-Agent Systems", "Planning and Reasoning", "Evaluation and Reliability"] }
        ]
    },
    "topics": [
        {
            "code": "AGT-CORE",
            "name": "Agent Concepts and Architecture",
            "level": "Foundation",
            "learningWeightPercent": 10,
            "subtopics": [
                {
                    "code": "AGT-CORE-1",
                    "name": "What is an AI Agent?",
                    "dotPoints": [
                        { "code": "AGT-CORE-1.1", "name": "Agents vs Chatbots vs Pipelines",         "keywords": ["agent definition", "autonomy", "goal-directed", "LLM chatbot", "pipeline", "agentic loop", "environment interaction", "perception action"], "difficulty": "foundation" },
                        { "code": "AGT-CORE-1.2", "name": "Core Agent Components",                    "keywords": ["LLM brain", "tools", "memory", "planner", "executor", "orchestrator", "agent loop", "observation", "thought", "action"], "difficulty": "foundation" },
                        { "code": "AGT-CORE-1.3", "name": "Agent Taxonomy",                           "keywords": ["reactive agent", "deliberative agent", "BDI agent", "tool-use agent", "autonomous agent", "assistant agent", "single-agent", "multi-agent"], "difficulty": "foundation" },
                        { "code": "AGT-CORE-1.4", "name": "The Agent Loop (Observe-Think-Act)",       "keywords": ["observe-think-act", "perception", "reasoning", "action execution", "feedback loop", "stopping condition", "max iterations", "task completion"], "difficulty": "foundation" }
                    ]
                },
                {
                    "code": "AGT-CORE-2",
                    "name": "LLM Fundamentals for Agents",
                    "dotPoints": [
                        { "code": "AGT-CORE-2.1", "name": "How LLMs Work (Transformer Basics)",      "keywords": ["transformer", "attention mechanism", "token", "context window", "temperature", "top-p", "sampling", "next token prediction", "prompt completion"], "difficulty": "foundation" },
                        { "code": "AGT-CORE-2.2", "name": "Context Window and Token Management",      "keywords": ["context window", "token limit", "GPT-4 128k", "Claude 200k", "token counting", "tiktoken", "context stuffing", "truncation strategies"], "difficulty": "intermediate" },
                        { "code": "AGT-CORE-2.3", "name": "Model Selection for Agents",              "keywords": ["GPT-4o", "Claude 3.5 Sonnet", "Gemini 1.5", "Llama 3", "open source vs proprietary", "cost per token", "latency", "reasoning capability", "function calling support"], "difficulty": "intermediate" },
                        { "code": "AGT-CORE-2.4", "name": "Structured Output and JSON Mode",         "keywords": ["structured output", "JSON mode", "response format", "Pydantic models", "output parsing", "instructor library", "schema validation", "guaranteed structure"], "difficulty": "intermediate" }
                    ]
                }
            ]
        },
        {
            "code": "AGT-PROMPT",
            "name": "Prompt Engineering for Agents",
            "level": "Foundation",
            "learningWeightPercent": 8,
            "subtopics": [
                {
                    "code": "AGT-PROMPT-1",
                    "name": "Core Prompting Techniques",
                    "dotPoints": [
                        { "code": "AGT-PROMPT-1.1", "name": "System Prompts and Role Assignment",    "keywords": ["system prompt", "role assignment", "persona", "instruction following", "guardrails", "agent identity", "task specification", "output format instructions"], "difficulty": "foundation" },
                        { "code": "AGT-PROMPT-1.2", "name": "Few-Shot and Zero-Shot Prompting",       "keywords": ["zero-shot", "few-shot", "in-context learning", "exemplars", "shot selection", "demonstrations", "chain-of-thought examples"], "difficulty": "foundation" },
                        { "code": "AGT-PROMPT-1.3", "name": "Chain-of-Thought (CoT) Prompting",      "keywords": ["chain-of-thought", "CoT", "step-by-step reasoning", "scratchpad", "rationale", "'Let's think step by step'", "zero-shot CoT", "few-shot CoT"], "difficulty": "intermediate" },
                        { "code": "AGT-PROMPT-1.4", "name": "ReAct Prompting Pattern",               "keywords": ["ReAct", "Reason + Act", "Thought", "Action", "Observation", "scratchpad", "interleaved reasoning", "grounded reasoning", "tool use with reasoning"], "difficulty": "intermediate" }
                    ]
                },
                {
                    "code": "AGT-PROMPT-2",
                    "name": "Advanced Reasoning Strategies",
                    "dotPoints": [
                        { "code": "AGT-PROMPT-2.1", "name": "Tree of Thoughts (ToT)",                "keywords": ["Tree of Thoughts", "ToT", "thought branching", "search over thoughts", "BFS DFS over reasoning", "self-evaluation", "backtracking", "deliberate problem solving"], "difficulty": "advanced" },
                        { "code": "AGT-PROMPT-2.2", "name": "Self-Consistency and Majority Voting",  "keywords": ["self-consistency", "majority voting", "sample multiple paths", "aggregate answers", "diverse reasoning", "robustness", "variance reduction"], "difficulty": "advanced" },
                        { "code": "AGT-PROMPT-2.3", "name": "Prompt Templates and Variables",        "keywords": ["PromptTemplate", "f-string templates", "Jinja2", "LangChain PromptTemplate", "input variables", "template composition", "dynamic prompts"], "difficulty": "intermediate" }
                    ]
                }
            ]
        },
        {
            "code": "AGT-TOOLS",
