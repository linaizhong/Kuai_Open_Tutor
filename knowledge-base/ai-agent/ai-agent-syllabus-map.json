                    "dotPoints": [
                        { "code": "AGT-MEM-2.1", "name": "Conversation Buffer and Summary Memory",   "keywords": ["ConversationBufferMemory", "ConversationSummaryMemory", "ConversationBufferWindowMemory", "summarisation", "k last messages", "memory variables", "return_messages"], "difficulty": "intermediate" },
                        { "code": "AGT-MEM-2.2", "name": "Vector Store Memory",                       "keywords": ["VectorStoreRetrieverMemory", "embedding memory", "semantic retrieval", "memory storage", "memory retrieval", "top-k similar memories", "faiss memory"], "difficulty": "intermediate" },
                        { "code": "AGT-MEM-2.3", "name": "LangGraph State and Checkpointing",        "keywords": ["LangGraph state", "StateGraph", "checkpointer", "MemorySaver", "SqliteSaver", "persistence", "thread_id", "resume from checkpoint", "stateful agent"], "difficulty": "advanced" }
                    ]
                }
