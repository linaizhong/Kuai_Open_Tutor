        {
            "code": "AGT-MEM",
            "name": "Memory Systems",
            "level": "Intermediate",
            "learningWeightPercent": 10,
            "subtopics": [
                {
                    "code": "AGT-MEM-1",
                    "name": "Memory Taxonomy",
                    "dotPoints": [
                        { "code": "AGT-MEM-1.1", "name": "Short-Term and In-Context Memory",          "keywords": ["in-context memory", "conversation history", "message list", "HumanMessage AIMessage", "sliding window", "token budget", "ConversationBufferMemory", "ChatMessageHistory"], "difficulty": "foundation" },
                        { "code": "AGT-MEM-1.2", "name": "Long-Term External Memory",                 "keywords": ["external memory", "vector store", "episodic memory", "semantic memory", "retrieval", "fuzzy search", "exact lookup", "Redis", "ChromaDB", "Pinecone"], "difficulty": "intermediate" },
                        { "code": "AGT-MEM-1.3", "name": "Episodic vs Semantic vs Procedural",       "keywords": ["episodic memory", "semantic memory", "procedural memory", "working memory", "declarative memory", "skill memory", "learned behaviours", "memory architecture"], "difficulty": "intermediate" }
                    ]
                },
                {
                    "code": "AGT-MEM-2",
