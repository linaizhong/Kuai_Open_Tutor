                    "dotPoints": [
                        { "code": "AGT-TOOLS-1.1", "name": "OpenAI Function Calling API",             "keywords": ["function calling", "tools parameter", "tool_choice", "function schema", "JSON schema", "name description parameters", "parallel tool calls", "tool result"], "difficulty": "intermediate" },
                        { "code": "AGT-TOOLS-1.2", "name": "Defining Tool Schemas",                   "keywords": ["tool schema", "JSON schema", "type string number boolean", "required properties", "description field", "enum values", "Pydantic tool definition", "schema best practices"], "difficulty": "intermediate" },
                        { "code": "AGT-TOOLS-1.3", "name": "Tool Selection and Routing",              "keywords": ["tool routing", "LLM selects tool", "tool description quality", "ambiguous tool names", "tool chaining", "sequential tool calls", "parallel tool calls"], "difficulty": "intermediate" }
                    ]
                },
                {
                    "code": "AGT-TOOLS-2",
                    "name": "Building Custom Tools",
                    "dotPoints": [
                        { "code": "AGT-TOOLS-2.1", "name": "LangChain @tool Decorator",               "keywords": ["@tool decorator", "BaseTool", "Tool class", "StructuredTool", "args_schema", "Pydantic BaseModel", "tool name", "tool description", "tool return type"], "difficulty": "intermediate" },
                        { "code": "AGT-TOOLS-2.2", "name": "Web Search and Browser Tools",            "keywords": ["Tavily", "SerpAPI", "DuckDuckGo search", "browser-use", "web scraping", "requests", "BeautifulSoup", "Playwright", "search tool integration"], "difficulty": "intermediate" },
                        { "code": "AGT-TOOLS-2.3", "name": "Code Execution Tools",                    "keywords": ["Python REPL", "E2B sandbox", "code interpreter", "safe execution", "subprocess", "sandboxed execution", "LangChain PythonREPLTool", "agent writes code"], "difficulty": "advanced" },
                        { "code": "AGT-TOOLS-2.4", "name": "Database and API Tools",                  "keywords": ["SQLDatabaseToolkit", "SQL agent", "REST API tool", "requests wrapper", "authenticated requests", "rate limiting", "error handling in tools", "Pydantic validation"], "difficulty": "intermediate" }
                    ]
                },
                {
                    "code": "AGT-TOOLS-3",
                    "name": "MCP — Model Context Protocol",
                    "dotPoints": [
                        { "code": "AGT-TOOLS-3.1", "name": "MCP Architecture and Concepts",           "keywords": ["Model Context Protocol", "MCP", "Anthropic", "MCP server", "MCP client", "tool provider", "resource provider", "standardised tool interface", "JSON-RPC"], "difficulty": "intermediate" },
                        { "code": "AGT-TOOLS-3.2", "name": "Building and Connecting MCP Servers",    "keywords": ["mcp Python SDK", "@mcp.tool", "@mcp.resource", "stdio transport", "SSE transport", "mcp server run", "Claude Desktop config", "tool registration", "LangChain MCP adapter"], "difficulty": "advanced" }
                    ]
                }
