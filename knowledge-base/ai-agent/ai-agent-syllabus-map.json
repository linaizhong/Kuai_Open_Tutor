                        { "code": "AGT-RAG-1.1", "name": "Why RAG? Problems it Solves",              "keywords": ["knowledge cutoff", "hallucination reduction", "private data", "grounding", "factuality", "context injection", "retrieval grounding", "RAG vs fine-tuning"], "difficulty": "foundation" },
                        { "code": "AGT-RAG-1.2", "name": "Embeddings and Vector Representations",   "keywords": ["embedding model", "text-embedding-3-small", "sentence-transformers", "cosine similarity", "dense vector", "embedding dimension", "semantic similarity", "OpenAI embeddings"], "difficulty": "intermediate" },
