                    "code": "LLM-NLP-1",
                    "name": "Language and Text Representation",
                    "dotPoints": [
                        { "code": "LLM-NLP-1.1", "name": "Text as Data: Challenges in NLP", "keywords": ["ambiguity", "context dependence", "compositionality", "discrete symbols", "sparse representation", "word meaning", "distributional hypothesis"], "difficulty": "foundation" },
