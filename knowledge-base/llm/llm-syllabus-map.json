                    "dotPoints": [
                        { "code": "LLM-NLP-2.1", "name": "Core NLP Tasks", "keywords": ["text classification", "named entity recognition", "question answering", "text generation", "summarisation", "translation", "sentiment analysis", "parsing"], "difficulty": "foundation" },
