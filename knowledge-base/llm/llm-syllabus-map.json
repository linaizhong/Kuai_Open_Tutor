                    "dotPoints": [
                        { "code": "LLM-TRF-3.1", "name": "Grouped-Query Attention and Multi-Query Attention", "keywords": ["GQA", "MQA", "grouped query attention", "multi-query attention", "KV cache sharing", "inference memory", "Llama 2", "Mistral", "head groups"], "difficulty": "advanced" },
                        { "code": "LLM-TRF-3.2", "name": "Mixture of Experts (MoE)", "keywords": ["MoE", "mixture of experts", "expert networks", "router", "sparse activation", "top-k routing", "Mixtral", "GShard", "Switch Transformer", "conditional compute"], "difficulty": "advanced" },
