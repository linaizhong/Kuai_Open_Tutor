    "rubrics": {
      "integrated": {
        "5": {
          "content": "Accurately represents all three points from both reading and lecture, clearly shows relationships",
          "organization": "Well-organized, each point clearly addressed, smooth transitions",
          "language": "Effective sentence variety, precise vocabulary, few errors"
        },
        "4": {
          "content": "Good representation of points, minor omission or inaccuracy",
          "organization": "Generally well-organized, some minor lapses",
          "language": "Some errors but meaning clear, adequate range"
        },
        "3": {
          "content": "Misses one point or misrepresents relationship",
          "organization": "Some organization, but may be repetitive or unclear",
          "language": "Noticeable errors, limited range"
        },
        "2": {
          "content": "Seriously misrepresents sources, omits key points",
          "organization": "Poor organization, difficult to follow",
          "language": "Frequent errors obscure meaning"
        },
        "1": {
          "content": "Minimal relevant content",
          "organization": "Lacks organization",
          "language": "Severe and persistent errors"
        },
        "0": "Blank, off-topic, or not in English"
      },
      "independent": {
        "5": {
          "development": "Well-developed, specific examples, insightful ideas",
          "organization": "Clear progression, effective transitions",
          "language": "Varied sentence structure, precise vocabulary, few errors"
        },
        "4": {
          "development": "Adequate development, some specifics",
          "organization": "Generally clear, minor lapses",
          "language": "Some variety, occasional errors"
        },
        "3": {
          "development": "Limited development, vague examples",
          "organization": "Some organization but may be repetitive",
          "language": "Limited range, noticeable errors"
        },
        "2": {
          "development": "Underdeveloped, lacks specifics",
          "organization": "Poor organization, hard to follow",
          "language": "Frequent errors obscure meaning"
        },
        "1": {
          "development": "Minimal or no development",
          "organization": "No discernible organization",
          "language": "Severe errors"
        },
        "0": "Blank, off-topic, or not in English"
      }
    },
    "questionTypeGuidelines": {
      "TOEFL-W.1": {
        "scoring": "See integrated rubric",
        "wordCount": "150-225 words recommended",
        "keyElements": [
