    "questionTypes": {
      "vocabulary": {
        "scoring": "1 point for correct answer",
        "commonErrors": [
          "Choosing dictionary definition instead of context meaning",
          "Selecting word with similar sound but different meaning"
        ]
      },
      "factual-information": {
        "scoring": "1 point for correct answer",
        "commonErrors": [
          "Selecting information not in passage",
          "Choosing true statement that doesn't answer the question"
        ]
      },
      "negative-fact": {
        "scoring": "1 point for correct answer",
        "commonErrors": [
          "Missing the 'EXCEPT' and selecting a true statement",
          "Overlooking that three options are mentioned, one is not"
        ]
      },
      "inference": {
        "scoring": "1 point for correct answer",
        "commonErrors": [
          "Choosing something that might be true but isn't required",
          "Using outside knowledge instead of passage content"
        ]
      },
      "rhetorical-purpose": {
        "scoring": "1 point for correct answer",
        "commonErrors": [
          "Describing what the text says rather than why",
          "Missing the author's intent"
        ]
      },
      "sentence-simplification": {
        "scoring": "1 point for correct answer",
        "commonErrors": [
          "Omitting key information",
          "Changing the meaning"
        ]
      },
      "insert-text": {
        "scoring": "1 point for correct answer",
        "commonErrors": [
          "Breaking pronoun reference chains",
          "Ignoring logical connectors"
        ]
      },
      "prose-summary": {
        "scoring": "2-3 points (partial credit available)",
        "criteria": [
          {"points": 3, "description": "All three correct answers selected"},
          {"points": 2, "description": "Two correct answers selected"},
          {"points": 1, "description": "One correct answer selected"},
          {"points": 0, "description": "No correct answers or all incorrect"}
        ],
        "commonErrors": [
          "Selecting minor details instead of main ideas",
          "Choosing statements not in the passage"
        ]
      }
    }
  },
  
