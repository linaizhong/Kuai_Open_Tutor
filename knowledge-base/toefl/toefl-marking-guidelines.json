    "rubrics": {
      "independent": {
        "4": {
          "delivery": "Generally well-paced, clear pronunciation, fluid expression",
          "language": "Effective use of grammar and vocabulary, good control",
          "development": "Well-developed with clear progression, specific examples"
        },
        "3": {
          "delivery": "Some minor lapses in pace or clarity, generally understandable",
          "language": "Some errors but meaning clear, adequate vocabulary",
          "development": "Adequate development with some specifics, mostly coherent"
        },
        "2": {
          "delivery": "Noticeable lapses, some effort for listener",
          "language": "Limited range, errors obscure meaning at times",
          "development": "Limited development, vague, some disconnection"
        },
        "1": {
          "delivery": "Significant problems, very difficult to understand",
          "language": "Severe errors, very limited vocabulary",
          "development": "Little or no development, disconnected ideas"
        },
        "0": "No response or response unrelated to topic"
      },
      "integrated": {
        "4": {
          "delivery": "Clear, fluid, good pace",
          "language": "Good control, appropriate vocabulary",
          "development": "Accurately represents source material, shows relationships clearly"
        },
        "3": {
          "delivery": "Generally clear, minor lapses",
          "language": "Some errors, meaning clear",
          "development": "Adequate representation, some connections shown"
        },
        "2": {
          "delivery": "Noticeable effort required",
          "language": "Limited, errors obscure meaning",
          "development": "Omits key points, unclear relationships"
        },
        "1": {
          "delivery": "Very difficult to understand",
          "language": "Severe limitations",
          "development": "Minimal source material, seriously distorted"
        },
        "0": "No response or unrelated"
      }
    },
    "questionTypeGuidelines": {
      "TOEFL-S.1": {
        "scoring": "See independent rubric",
        "keyElements": [
          "State preference clearly",
          "Give at least two reasons",
          "Provide specific examples",
          "Stay on topic"
        ]
      },
      "TOEFL-S.2": {
        "scoring": "See independent rubric",
        "keyElements": [
          "Make clear choice",
          "Explain why chosen option is better",
          "Use comparison language",
          "Provide specific examples"
        ]
      },
      "TOEFL-S.3": {
        "scoring": "See integrated rubric",
        "keyElements": [
          "State speaker's opinion",
          "Report reasons accurately",
          "Connect to reading context",
          "Complete within time"
        ]
      },
      "TOEFL-S.4": {
        "scoring": "See integrated rubric",
        "keyElements": [
          "State concept from reading",
          "Explain each example from lecture",
          "Connect examples to concept",
          "Complete within time"
        ]
      }
    }
